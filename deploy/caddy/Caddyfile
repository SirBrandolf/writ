# HTTP on port 80: Express on :5000 (/health, /api/*), SPA on :5175 (/, /notes/*, etc.).
# Requires writ-server and writ-client (or equivalent) running locally.
# Add your real public origin to CORS_ORIGINS in /etc/app.env (e.g. https://your.domain).

:80 {
	@api {
		path /health
		path /api /api/*
	}
	handle @api {
		reverse_proxy localhost:5000
	}
	handle {
		reverse_proxy localhost:5175
	}
}
