# HTTP on port 80: API on :5000, Vite preview on :5175.
# Requires writ-server and writ-client (or equivalent) running locally.
# After switching browsers to http://YOUR_IP/, update Express CORS for that origin.

:80 {
	@api {
		path /health
		path /notes /notes/*
	}
	handle @api {
		reverse_proxy localhost:5000
	}
	handle {
		reverse_proxy localhost:5175
	}
}
